{
    "name": "@ilingo/validup-vue",
    "type": "module",
    "version": "1.0.1",
    "description": "Vue 3 plugin + composables that wire @ilingo/validup into a Vue app.",
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build:js": "tsdown",
        "build:types": "vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json",
        "build": "npm run build:js && npm run build:types",
        "test": "vitest --config test/vitest.config.ts --run",
        "test:coverage": "vitest --config test/vitest.config.ts --run --coverage",
        "lint": "eslint",
        "lint:fix": "npm run lint -- --fix"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "keywords": [
        "ilingo",
        "validup",
        "validation",
        "i18n",
        "translation",
        "vue"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/ilingo.git",
        "directory": "packages/validup-vue"
    },
    "bugs": {
        "url": "https://github.com/tada5hi/ilingo/issues"
    },
    "homepage": "https://github.com/tada5hi/ilingo#readme",
    "devDependencies": {
        "@ilingo/validup": "^1.0.1",
        "@ilingo/vue": "^6.0.0",
        "@validup/vue": "^0.3.3",
        "@vitejs/plugin-vue": "^6.0.3",
        "@vue/test-utils": "^2.4.11",
        "@vueuse/core": "^14.1.0",
        "happy-dom": "^20.10.2",
        "ilingo": "^6.0.0",
        "validup": "^0.5.1",
        "vite": "^8.0.16",
        "vitest": "^4.1.5",
        "vue": "^3.5.35"
    },
    "peerDependencies": {
        "@ilingo/validup": "^1.0.1",
        "@ilingo/vue": "^6.0.0",
        "@validup/vue": "^0.3.3",
        "@vueuse/core": "^14.1.0",
        "ilingo": "^6.0.0",
        "validup": "^0.5.1",
        "vue": "^3.5.35"
    },
    "publishConfig": {
        "access": "public"
    }
}
