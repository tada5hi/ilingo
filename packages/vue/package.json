{
    "name": "@ilingo/vue",
    "type": "module",
    "version": "5.0.0",
    "description": "This package contains the vue package of ilingo.",
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        },
        "./core": {
            "types": "./core/index.d.ts",
            "import": "./core/index.mjs",
            "require": "./core/index.js"
        }
    },
    "files": [
        "core",
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "build:js": "tsdown",
        "build:types": "vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json",
        "build": "npm run build:js && npm run build:types",
        "lint": "eslint",
        "lint:fix": "npm run lint -- --fix"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "keywords": [],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/ilingo.git",
        "directory": "packages/vue"
    },
    "bugs": {
        "url": "https://github.com/tada5hi/ilingo/issues"
    },
    "homepage": "https://github.com/tada5hi/ilingo#readme",
    "devDependencies": {
        "@vueuse/core": "^14.1.0",
        "ilingo": "^5.0.0",
        "vite": "^8.0.14",
        "vue": "^3.5.26"
    },
    "peerDependencies": {
        "@vueuse/core": "^14.1.0",
        "ilingo": "^5.0.0",
        "vue": "^3.5.26"
    },
    "publishConfig": {
        "access": "public"
    }
}
