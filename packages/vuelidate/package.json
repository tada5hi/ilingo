{
    "name": "@ilingo/vuelidate",
    "type": "module",
    "version": "6.0.0",
    "description": "This package contains a vuelidate plugin for ilingo.",
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        },
        "./store/memory": {
            "types": "./dist/store/memory.d.ts",
            "import": "./dist/store/memory.mjs"
        },
        "./store/loader": {
            "types": "./dist/store/loader.d.ts",
            "import": "./dist/store/loader.mjs"
        },
        "./core": {
            "types": "./core/index.d.ts",
            "import": "./core/index.mjs",
            "require": "./core/index.js"
        },
        "./vue": {
            "types": "./vue/index.d.ts",
            "import": "./vue/index.mjs",
            "require": "./vue/index.js"
        }
    },
    "files": [
        "dist",
        "core",
        "vue"
    ],
    "scripts": {
        "dev": "vite",
        "build:js": "tsdown",
        "build:types": "vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json",
        "build": "npm run build:js && npm run build:types",
        "lint": "eslint",
        "lint:fix": "npm run lint -- --fix"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "keywords": [],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/ilingo.git",
        "directory": "packages/vuelidate"
    },
    "bugs": {
        "url": "https://github.com/tada5hi/ilingo/issues"
    },
    "homepage": "https://github.com/tada5hi/ilingo#readme",
    "devDependencies": {
        "@ilingo/vue": "^5.0.0",
        "@vuelidate/core": "^2.0.3",
        "@vuelidate/validators": "^2.0.4",
        "@vueuse/core": "^14.1.0",
        "ilingo": "^5.0.0",
        "vite": "^8.0.16",
        "vue": "^3.5.35"
    },
    "peerDependencies": {
        "@ilingo/vue": "^5.0.0",
        "@vuelidate/core": "^2.0.3",
        "@vueuse/core": "^14.1.0",
        "ilingo": "^5.0.0",
        "vue": "^3.5.35"
    },
    "publishConfig": {
        "access": "public"
    }
}
